# NogoChain Explorer 环境变量配置示例
# 复制此文件为 .env 并修改相应值

# ===========================================
# 网络配置
# ===========================================
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# ===========================================
# MongoDB 配置
# ===========================================
# 本地开发环境（无认证）
# MONGODB_URI=mongodb://localhost:27017/explorerDB

# 生产环境（带认证）
MONGODB_URI=mongodb://explorer:your_secure_password@localhost:27017/explorerDB?authSource=explorerDB

# MongoDB 连接池配置
MONGODB_MAX_POOL_SIZE=50
MONGODB_SERVER_SELECTION_TIMEOUT_MS=15000
MONGODB_SOCKET_TIMEOUT_MS=60000
MONGODB_CONNECT_TIMEOUT_MS=15000

# ===========================================
# NogoChain 节点配置
# ===========================================
# HTTP RPC 端点
WEB3_PROVIDER_URL=http://localhost:8545

# WebSocket 端点
WS_PROVIDER_URL=ws://localhost:8546

# Chain ID
CHAIN_ID=318

# ===========================================
# API 配置
# ===========================================
# 公共 API URL（用于前端）
NEXT_PUBLIC_API_URL=http://localhost:3000

# API 速率限制
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=100

# ===========================================
# 安全配置
# ===========================================
# JWT 密钥（用于需要认证的功能）
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# CORS 配置
CORS_ORIGIN=https://explorer.nogochain.org

# ===========================================
# 性能配置
# ===========================================
# Node.js 内存限制（MB）
NODE_OPTIONS=--max-old-space-size=2048

# 缓存配置
CACHE_ENABLED=true
CACHE_DURATION=300

# ===========================================
# 日志配置
# ===========================================
LOG_LEVEL=info
LOG_FILE_ENABLED=true
LOG_CONSOLE_ENABLED=true

# ===========================================
# 功能开关
# ===========================================
ENABLE_NFT=true
ENABLE_CONTRACT_VERIFICATION=true
ENABLE_TOKEN_TRACKING=true
ENABLE_RICHLIST=true
ENABLE_STATISTICS=true

# ===========================================
# DEX 配置（可选）
# ===========================================
DEX_ENABLED=false
DEX_FACTORY_ADDRESS=0x0000000000000000000000000000000000000000
DEX_ROUTER_ADDRESS=0x0000000000000000000000000000000000000000
DEX_MASTERCHEF_ADDRESS=0x0000000000000000000000000000000000000000

# ===========================================
# Launchpad 配置（可选）
# ===========================================
LAUNCHPAD_ENABLED=true
LAUNCHPAD_FACTORY_ADDRESS=0x0000000000000000000000000000000000000000

# ===========================================
# 监控配置（可选）
# ===========================================
ENABLE_PROMETHEUS=false
PROMETHEUS_PORT=9090

# ===========================================
# 备份配置（可选）
# ===========================================
BACKUP_ENABLED=false
BACKUP_DIR=/backup/nogo-explorer
BACKUP_INTERVAL=86400
